# Email Configuration for Password Reset
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@lensandluxe.com

# Fashion News API Configuration
# Uses GNews by default: https://gnews.io/
FASHION_NEWS_API_KEY=your-gnews-api-key
FASHION_NEWS_API_URL=https://gnews.io/api/v4/search
FASHION_NEWS_QUERY=fashion OR runway OR couture OR designer OR luxury style
FASHION_NEWS_LANG=en
FASHION_NEWS_COUNTRY=us
FASHION_NEWS_MAX_RESULTS=10
FASHION_NEWS_REFRESH_MINUTES=30
SERPAPI_KEY=your_actual_alphanumeric_key_here

# For Gmail, you need to generate an App Password:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Select "Mail" and "Windows Computer" (or your device)
# 4. Generate password and use it above as MAIL_PASSWORD

# For other email providers, adjust MAIL_SERVER accordingly:
# - Outlook/Hotmail: smtp.office365.com
# - Yahoo: smtp.mail.yahoo.com
# - SendGrid: smtp.sendgrid.net
